rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    function isDoctor() {
      return isSignedIn() && getUserData().role == 'doctor';
    }

    function isPatient() {
      return isSignedIn() && getUserData().role == 'patient';
    }

    // ─── Users ───────────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Doctors ─────────────────────────────────────────────────────────────

    match /doctors/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid) || isAdmin();
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();

      // Doctor slots subcollection
      match /slots/{slotId} {
        allow read: if isSignedIn();
        allow create, update: if isOwner(uid) || isAdmin() || isPatient();
        allow delete: if isOwner(uid) || isAdmin();
      }
    }

    // ─── Appointments ─────────────────────────────────────────────────────────

    match /appointments/{apptId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId  == request.auth.uid
      );
      allow create: if isSignedIn() && isPatient();
      allow update: if isSignedIn() && (
        isAdmin() ||
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId  == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // ─── Chats ────────────────────────────────────────────────────────────────

    match /chats/{chatId} {
      allow read, write: if isSignedIn() &&
        request.auth.uid in resource.data.participants;

      match /messages/{msgId} {
        allow read: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants ||
          // Allow creating new chat
          true;
        allow update: if isSignedIn();
        allow delete: if isAdmin();
      }
    }

    // ─── Reviews ─────────────────────────────────────────────────────────────

    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isPatient();
      allow update, delete: if isAdmin();
    }
  }
}
