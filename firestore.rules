rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    function isDoctor() {
      return isSignedIn() && getUserData().role == 'doctor';
    }

    function isPatient() {
      return isSignedIn() && getUserData().role == 'patient';
    }

    // ─── Users ───────────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Doctors ─────────────────────────────────────────────────────────────

    match /doctors/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid) || isAdmin();
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();

      // Doctor slots subcollection
      match /slots/{slotId} {
        allow read: if isSignedIn();
        allow create, update: if isOwner(uid) || isAdmin() || isPatient();
        allow delete: if isOwner(uid) || isAdmin();
      }

      // Doctor reviews subcollection
      match /reviews/{reviewId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isPatient();
        allow update, delete: if isAdmin();
      }
    }

    // ─── Appointments ─────────────────────────────────────────────────────────

    match /appointments/{apptId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId  == request.auth.uid
      );
      allow create: if isSignedIn() && isPatient();
      allow update: if isSignedIn() && (
        isAdmin() ||
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId  == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // ─── Chats ────────────────────────────────────────────────────────────────

    match /chats/{chatId} {
      // Use request.resource for creates (resource.data is null on create).
      allow read: if isSignedIn() &&
        request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() &&
        request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() &&
        request.auth.uid in resource.data.participants;
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow update: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow delete: if isAdmin();
      }
    }

    // ─── Prescriptions ────────────────────────────────────────────────────────

    match /prescriptions/{prescriptionId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId  == request.auth.uid
      );
      allow create: if isSignedIn() && isDoctor();
      allow update: if isSignedIn() && (
        isAdmin() ||
        resource.data.doctorId == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // ─── Notifications ────────────────────────────────────────────────────────

    match /notifications/{notificationId} {
      allow read: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ─── Reviews (top-level, legacy) ──────────────────────────────────────────

    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isPatient();
      allow update, delete: if isAdmin();
    }

    // ─── App Metadata ─────────────────────────────────────────────────────────

    match /meta/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}

